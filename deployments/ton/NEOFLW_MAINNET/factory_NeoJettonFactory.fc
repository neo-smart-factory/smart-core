;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps) = $NeoJettonFactory$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
        ;; Receive DeployJetton message
        if (op == 0x61caf729) {
            var $msg'owner = in_msg~load_msg_addr();
            var $msg'content = in_msg~load_ref();
            var $msg'max_supply = in_msg~load_varuint16();
            var $msg'mint_price = in_msg~load_varuint16();
            var $msg'mint_amount = in_msg~load_varuint16();
            var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
            throw_unless(61788, (~ $self'paused));
            throw_unless(5239, ($ctx'value >= 400000000));
            throw_unless(49334, ($msg'max_supply > 0));
            throw_unless(60484, ($msg'max_supply <= 1000000000000000000000000000));
            var ($init'code, $init'data) = $NeoJettonMinter$_init_child($msg'owner, $msg'content, $msg'max_supply, $msg'mint_price, $msg'mint_amount, $self'treasury);
            slice $jettonAddress = $global_contractAddress(($init'code, $init'data));
            $global_send($SendParameters$_constructor_to_value_mode_body_code_data($jettonAddress, ($ctx'value - 50000000), 1, $Deploy$_store_cell($Deploy$_constructor_queryId(0), begin_cell()), $init'code, $init'data));
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
        ;; Receive Pause message
        if (op == 0x10000001) {
            var $msg = empty_tuple();
            throw_unless(42435, ( (( equal_slices_bits(__tact_context_get_sender(), $self'owner) )) ? (true) : (( equal_slices_bits(__tact_context_get_sender(), $self'guardian) )) ));
            $self'paused = true;
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
        ;; Receive Unpause message
        if (op == 0x10000002) {
            var $msg = empty_tuple();
            throw_unless(1521, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
            $self'paused = false;
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
        ;; Receive SetGuardian message
        if (op == 0x10000003) {
            var $msg'address = in_msg~load_msg_addr();
            ($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps)~$NeoJettonFactory$_fun_requireOwner();
            $self'guardian = $msg'address;
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
        ;; Receive SetTreasury message
        if (op == 0x10000004) {
            var $msg'address = in_msg~load_msg_addr();
            ($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps)~$NeoJettonFactory$_fun_requireOwner();
            $self'treasury = $msg'address;
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
        ;; Receive SetFee message
        if (op == 0x10000005) {
            var $msg'bps = in_msg~load_int(257);
            ($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps)~$NeoJettonFactory$_fun_requireOwner();
            throw_unless(46136, ($msg'bps <= 2000));
            $self'fee_bps = $msg'bps;
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
        ;; Receive Deploy message
        if (op == 0x946a98b6) {
            var $deploy'queryId = in_msg~load_uint(64);
            ($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps)~$NeoJettonFactory$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
            $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
            return ();
        }
        
    }
    ;; Empty Receiver and Text Receivers
    var text_op = slice_hash(in_msg);
    ;; Receive "withdraw" message
    if (text_op == 0x158e394e7cc73a9aeb362957fe037665588aef16f3bd68580c13ab84097cf22a) {
        ($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps)~$NeoJettonFactory$_fun_requireOwner();
        $global_send($SendParameters$_constructor_to_value_mode($self'owner, 0, 128));
        $NeoJettonFactory$_contract_store(($self'owner, $self'treasury, $self'guardian, $self'paused, $self'fee_bps));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}
