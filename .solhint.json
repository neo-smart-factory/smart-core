{
    "extends": "solhint:recommended",
    "plugins": [],
    "rules": {
        "compiler-version": [
            "error",
            "^0.8.20"
        ],
        "func-visibility": [
            "warn",
            {
                "ignoreConstructors": true
            }
        ],
        "max-line-length": [
            "warn",
            120
        ],
        "not-rely-on-time": "off",
        "no-empty-blocks": "warn",
        "reason-string": [
            "warn",
            {
                "maxLength": 64
            }
        ],
        "no-unused-vars": "warn",
        "const-name-snakecase": "warn",
        "no-console": "off",
        "no-global-import": "off"
    }
}