    ;; Receive "withdraw" message
    if (text_op == 0x158e394e7cc73a9aeb362957fe037665588aef16f3bd68580c13ab84097cf22a) {
        ($self'total_supply, $self'owner, $self'content, $self'max_supply, $self'mint_price, $self'mint_amount, $self'public_mint_enabled, $self'bridge_minter, $self'paused, $self'guardian, $self'treasury, $self'fee_bps, $self'minters)~$NeoJettonMinter$_fun_requireOwner();
        int $balance = $global_myBalance();
        int $withdrawAmount = ($balance - 50000000);
        if (($withdrawAmount > 0)) {
            int $protocolPart = (($withdrawAmount * $self'fee_bps) / 10000);
            $global_send($SendParameters$_constructor_to_value_mode($self'treasury, $protocolPart, 1));
            $global_send($SendParameters$_constructor_to_value_mode($self'owner, ($withdrawAmount - $protocolPart), 1));
        }
        $NeoJettonMinter$_contract_store(($self'total_supply, $self'owner, $self'content, $self'max_supply, $self'mint_price, $self'mint_amount, $self'public_mint_enabled, $self'bridge_minter, $self'paused, $self'guardian, $self'treasury, $self'fee_bps, $self'minters));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}
