    "hardhat": "^2.22.0",
    "jest": "^29.7.0",
    "qs": "^6.14.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
