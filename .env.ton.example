# TON Network - Configuration Template
# Renomeie para .env antes de usar. NUNCA commite o arquivo .env real.

# 1. Deployer Wallet (Mnemônico de 24 palavras)
# Obrigatório para scripts de deploy (Hardhat/Blueprint/Scripts locais)
# NÃO necessário se o deploy for feito apenas via Frontend (TON Connect)
TON_DEPLOYER_MNEMONIC="word1 word2 word3 ... word24"

# 2. Network Environment
# 'testnet' ou 'mainnet'
TON_NETWORK="testnet"

# 3. API Keys (Recomendado para estabilidade, mas opcional em testes baixos)
# Obtenha em: https://toncenter.com/ ou https://t.me/tonapibot
TON_API_KEY=""

# 4. Protocol Addresses (Deixe vazio inicialmente, preencha após deploy)
# Endereço do contrato NeoJettonFactory deployado
VITE_NEO_JETTON_FACTORY_ADDRESS=""

# Endereço da Treasury (para coletar taxas do protocolo, se aplicável)
VITE_PROTOCOL_TREASURY_ADDRESS="EQ..."

# 5. Parâmetros de Deploy
# Valor em TON a ser enviado para cobrir fees e storage inicial do Jetton
# Recomendado: 0.25 TON
JETTON_DEPLOY_AMOUNT="0.25"
