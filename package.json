  "repository": {
    "type": "git",
    "url": "https://github.com/neo-smart-token-factory/smart-core.git"
  },
  "homepage": "https://github.com/neo-smart-token-factory/smart-core#readme",
  "scripts": {
    "test": "npx hardhat test",
    "test:ton": "jest test/ton",
    "compile": "npx hardhat compile",
    "compile:ton": "npx tact --config tact.config.json",
    "deploy:polygon": "npx hardhat run scripts/deployV2.js --network polygon",
    "deploy:base": "npx hardhat run scripts/deployV2.js --network base",
    "verify:base": "npx hardhat verify --network base",
    "verify:polygon": "npx hardhat verify --network polygon",
    "security:check": "node scripts/security/validate-vault.js",
    "security:manifesto": "node scripts/security/generate-token-manifesto.js",
    "nexus:start": "node scripts/nexus-ingress.js"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "polygon",
    "base",
    "smart-contracts",
    "factory",
    "tokens",
    "neo-protocol"
  ],
  "author": "NΞØ Protocol",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@tact-lang/compiler": "^1.6.0",
    "@ton-community/func-js": "^0.11.0",
    "@ton/core": "^0.63.0",
    "@ton/crypto": "^3.3.0",
    "@ton/sandbox": "^0.20.0",
