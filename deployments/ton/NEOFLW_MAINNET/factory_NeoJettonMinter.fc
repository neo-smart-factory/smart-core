        if (($balanceBeforeMessage < 0)) {
            $global_nativeReserve(0, 0);
            $global_message($MessageParameters$_constructor_bounce_to_value_mode_body($bounce, $to, 0, 130, $body));
            return (($self'total_supply, $self'owner, $self'content, $self'max_supply, $self'mint_price, $self'mint_amount, $self'public_mint_enabled, $self'bridge_minter, $self'paused, $self'guardian, $self'treasury, $self'fee_bps, $self'minters), ());
        }
    }
    $global_message($MessageParameters$_constructor_bounce_to_value_mode_body($bounce, $to, 0, 66, $body));
    return (($self'total_supply, $self'owner, $self'content, $self'max_supply, $self'mint_price, $self'mint_amount, $self'public_mint_enabled, $self'bridge_minter, $self'paused, $self'guardian, $self'treasury, $self'fee_bps, $self'minters), ());
}

((int, slice, cell, int, int, int, int, slice, int, slice, slice, int, cell), ()) $NeoJettonMinter$_fun_requireOwner((int, slice, cell, int, int, int, int, slice, int, slice, slice, int, cell) $self) impure inline_ref {
